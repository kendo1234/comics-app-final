# Copy this file to scripts/aws/env.sh and fill values.

export AWS_REGION="us-east-1"
export PROJECT_NAME="comics-app"
export ENV_NAME="dev"

# Required for HTTPS listener on ALB.
# Create/import a public ACM certificate in the same region and set ARN here.
export ALB_CERT_ARN="arn:aws:acm:us-east-1:123456789012:certificate/replace-me"

# Optional overrides
export APP_PORT="8080"
export DESIRED_COUNT="1"
export DDB_TABLE_NAME="comics"
export COGNITO_DOMAIN_PREFIX="comicsapp-dev-auth"
export APP_IMAGE_TAG="latest"

# Optional: set if you want a custom app name in ECS/ECR resources
# export APP_NAME="comics-web"
